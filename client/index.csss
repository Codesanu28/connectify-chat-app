* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  background: #0f172a;
  color: white;
  font-family: Arial, sans-serif;
}

a {
  color: white;
  text-decoration: none;
}

input {
  padding: 12px;
  border: none;
  outline: none;
  border-radius: 8px;
}

button {
  padding: 12px 20px;
  border: none;
  background: #2563eb;
  color: white;
  border-radius: 8px;
  cursor: pointer;
}

button:hover {
  background: #1d4ed8;
}